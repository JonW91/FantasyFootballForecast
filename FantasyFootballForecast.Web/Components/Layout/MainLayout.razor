@inherits LayoutComponentBase

<div class="page app-shell">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <main>
        <div class="top-row px-4 top-bar">
            <div>
                <p class="eyebrow">Fantasy Football Forecast</p>
                <h1>Premier League intelligence in one place</h1>
            </div>
            <a class="top-link" href="https://fantasy.premierleague.com/" target="_blank">Official FPL</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
