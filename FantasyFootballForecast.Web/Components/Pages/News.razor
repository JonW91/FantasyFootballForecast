@page "/news"
@rendermode InteractiveServer
@inject FootballApiClient Api

<PageTitle>News</PageTitle>

<div class="panel">
    <div class="hero-copy mb-3">
        Scan the latest player news and availability context before you move to the picks page.
    </div>
    @if (items is null)
    {
        <p>Loading...</p>
    }
    else
    {
        <div class="hero-stats mb-3">
            <div><span>@items.Count</span><label>Loaded</label></div>
            <div><span>@items.Count(item => item.InjuryFlag)</span><label>Injury</label></div>
            <div><span>@items.Count(item => item.SuspensionFlag)</span><label>Suspension</label></div>
        </div>

        @if (items.Count == 0)
        {
            <p>No news items are available yet.</p>
        }
        else
        {
            @foreach (var item in items)
            {
                <article class="news-card">
                    <div class="news-meta">
                        <span>@item.SourceName</span>
                        <span>@item.PublishedUtc.ToString("dd MMM HH:mm")</span>
                    </div>
                    <h3>@item.Title</h3>
                    <p>@item.Summary</p>
                    <div class="news-badges">
                        @if (item.InjuryFlag)
                        {
                            <span class="badge badge-warning">Injury</span>
                        }
                        @if (item.SuspensionFlag)
                        {
                            <span class="badge badge-bad">Suspension</span>
                        }
                        @if (item.AvailableFlag)
                        {
                            <span class="badge badge-good">Available</span>
                        }
                    </div>
                </article>
            }
        }
    }
</div>

@code {
    private List<NewsItemDto>? items;
    protected override async Task OnInitializedAsync() => items = await Api.GetNewsAsync() ?? [];
}
