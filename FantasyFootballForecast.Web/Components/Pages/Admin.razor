@page "/admin"
@rendermode InteractiveServer
@inject FootballApiClient Api

<PageTitle>Data Sync</PageTitle>

<div class="panel">
    <div class="hero-copy mb-3">
        Trigger data sync and model training manually when you want to refresh the prototype on demand.
    </div>
    <div class="button-row">
        <button class="btn btn-primary" disabled="@isBusy" @onclick="SyncAll">Sync all providers</button>
        <button class="btn btn-outline-light" disabled="@isBusy" @onclick="SyncFpl">Sync FPL</button>
        <button class="btn btn-outline-light" disabled="@isBusy" @onclick="BackfillHistorical">Backfill history</button>
        <button class="btn btn-outline-light" disabled="@isBusy" @onclick="SyncTheSportsDb">Sync TheSportsDB</button>
        <button class="btn btn-outline-light" disabled="@isBusy" @onclick="SyncApiFootball">Sync API-Football</button>
        <button class="btn btn-outline-light" disabled="@isBusy" @onclick="RetrainAll">Retrain both models</button>
        <button class="btn btn-outline-light" disabled="@isBusy" @onclick="TrainPlayers">Train player model</button>
        <button class="btn btn-outline-light" disabled="@isBusy" @onclick="TrainTeams">Train team model</button>
    </div>

    <div class="hero-stats mt-3">
        <div><span>@buttonCount</span><label>Actions</label></div>
        <div><span>@(isBusy ? "Busy" : "Ready")</span><label>Status</label></div>
    </div>

    <div class="hero-stats mt-3">
        <div><span>@(latestModelRun?.Status ?? "None")</span><label>Latest model</label></div>
        <div><span>@(latestIngestionRun?.Status ?? "None")</span><label>Latest sync</label></div>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p class="mt-3">@message</p>
    }
</div>

@code {
    private string? message;
    private bool isBusy;
    private ModelTrainingRunDto? latestModelRun;
    private DataIngestionRunDto? latestIngestionRun;
    private const int buttonCount = 8;

    protected override async Task OnInitializedAsync()
    {
        await RefreshRunsAsync();
    }

    private Task SyncAll() => ExecuteAsync("Sync all providers", () => Api.SyncAsync());

    private Task SyncFpl() => ExecuteAsync("Sync FPL", () => Api.SyncAsync("FPL Public API"));

    private Task BackfillHistorical() => ExecuteAsync("Backfill history", () => Api.SyncHistoricalAsync("FPL Public API"));

    private Task SyncTheSportsDb() => ExecuteAsync("Sync TheSportsDB", () => Api.SyncAsync("TheSportsDB"));

    private Task SyncApiFootball() => ExecuteAsync("Sync API-Football", () => Api.SyncAsync("API-Football"));

    private Task RetrainAll() => ExecuteAsync("Retrain both models", () => Api.RetrainAsync());

    private Task TrainPlayers() => ExecuteAsync("Train player model", () => Api.TrainAsync());

    private Task TrainTeams() => ExecuteAsync("Train team model", () => Api.TrainAsync("team"));

    private async Task ExecuteAsync<T>(string actionName, Func<Task<T?>> action)
    {
        if (isBusy)
        {
            return;
        }

        isBusy = true;
        message = $"{actionName} running...";

        try
        {
            var result = await action();
            message = result switch
            {
                DataIngestionRunDto run => $"{actionName} completed: {run.Status} ({run.ItemsProcessed} items).",
                ModelTrainingSummaryDto summary => $"{actionName} completed: {summary.Status} with metric {summary.MetricName} {summary.MetricValue}.",
                _ => $"{actionName} completed."
            };
            await RefreshRunsAsync();
        }
        catch (Exception ex)
        {
            message = $"{actionName} failed: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task RefreshRunsAsync()
    {
        latestModelRun = (await Api.GetModelRunsAsync())?.FirstOrDefault();
        latestIngestionRun = (await Api.GetIngestionRunsAsync())?.FirstOrDefault();
    }
}
