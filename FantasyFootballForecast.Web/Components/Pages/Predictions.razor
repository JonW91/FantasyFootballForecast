@page "/predictions"
@rendermode InteractiveServer
@inject FootballApiClient Api

<PageTitle>Predictions</PageTitle>

<div class="grid-2">
    <article class="panel">
        <div class="hero-copy mb-3">
            Inspect the persisted prediction table directly while the model layer is still maturing.
        </div>
        <h3>Match predictions</h3>
        @if (predictions is null)
        {
            <p>Loading...</p>
        }
        else
        {
            <div class="hero-stats mb-3">
                <div><span>@predictions.Count</span><label>Loaded</label></div>
                <div><span>@predictions.Count(prediction => prediction.PredictionKind == PredictionKind.MatchOutcome)</span><label>Matches</label></div>
                <div><span>@predictions.Count(prediction => prediction.PredictionKind == PredictionKind.PlayerFantasyPoints)</span><label>Players</label></div>
            </div>

            @if (predictions.Count == 0)
            {
                <p>No predictions are available yet.</p>
            }
            else
            {
                @foreach (var prediction in predictions)
                {
                    <div class="list-row">
                        <span>@prediction.PredictionKind</span>
                        <strong>@prediction.PredictedValue</strong>
                    </div>
                }
            }
        }
    </article>
    <article class="panel">
        <h3>Projection notes</h3>
        <div class="list-row">
            <span>Storage</span>
            <strong>SQL Server</strong>
        </div>
        <div class="list-row">
            <span>Current scope</span>
            <strong>Persisted read model</strong>
        </div>
        <div class="list-row">
            <span>Next split</span>
            <strong>Match vs player projections</strong>
        </div>
    </article>
</div>

@code {
    private List<PredictionDto>? predictions;

    protected override async Task OnInitializedAsync()
        => predictions = await Api.GetPredictionsAsync() ?? [];
}
