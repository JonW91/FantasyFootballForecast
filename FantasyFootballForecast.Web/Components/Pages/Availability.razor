@page "/availability"
@rendermode InteractiveServer
@inject FootballApiClient Api

<PageTitle>Availability</PageTitle>

<div class="panel">
    <div class="hero-copy mb-3">
        Track injury, suspension, and availability flags before setting a fantasy squad.
    </div>
    @if (items is null)
    {
        <p>Loading...</p>
    }
    else
    {
        <div class="hero-stats mb-3">
            <div><span>@items.Count</span><label>Loaded</label></div>
            <div><span>@items.Count(item => item.AvailabilityStatus == AvailabilityStatus.Available)</span><label>Available</label></div>
            <div><span>@items.Count(item => item.AvailabilityStatus != AvailabilityStatus.Available)</span><label>Flagged</label></div>
        </div>

        @if (items.Count == 0)
        {
            <p>No availability records are available yet.</p>
        }
        else
        {
            @foreach (var item in items)
            {
                <div class="list-row">
                    <span>@item.PlayerName - @item.TeamName</span>
                    <strong class="badge @BadgeClass(item.AvailabilityStatus)">@item.AvailabilityStatus</strong>
                </div>
            }
        }
    }
</div>

@code {
    private List<AvailabilityDto>? items;
    protected override async Task OnInitializedAsync() => items = await Api.GetAvailabilityAsync() ?? [];
    private static string BadgeClass(AvailabilityStatus status) => status switch
    {
        AvailabilityStatus.Available => "badge-good",
        AvailabilityStatus.Doubtful => "badge-warning",
        AvailabilityStatus.Injured or AvailabilityStatus.RuledOut or AvailabilityStatus.Suspended => "badge-bad",
        _ => "badge-neutral"
    };
}
