@page "/players"
@rendermode InteractiveServer
@inject FootballApiClient Api

<PageTitle>Players</PageTitle>

<div class="panel">
    <div class="hero-copy mb-3">
        Search the player pool, compare form and value, and jump into player detail views.
    </div>
    <div class="row g-2 mb-3">
        <div class="col-md-5">
            <input class="form-control" placeholder="Search players" @bind="search" @bind:event="oninput" />
        </div>
        <div class="col-md-3">
            <select class="form-select" @bind="positionFilter">
                <option value="">All positions</option>
                <option value="GK">GK</option>
                <option value="DEF">DEF</option>
                <option value="MID">MID</option>
                <option value="FWD">FWD</option>
            </select>
        </div>
        <div class="col-md-2">
            <select class="form-select" @bind="sortMode">
                <option value="form">Recent form</option>
                <option value="points">Recent points</option>
                <option value="price">Price</option>
            </select>
        </div>
    </div>

    @if (players is null)
    {
        <p>Loading...</p>
    }
    else
    {
        var visiblePlayers = FilteredPlayers.ToList();

        <div class="hero-stats mb-3">
            <div><span>@players.Count</span><label>Loaded</label></div>
            <div><span>@visiblePlayers.Count</span><label>Visible</label></div>
            <div><span>@(string.IsNullOrEmpty(positionFilter) ? "All" : positionFilter)</span><label>Position</label></div>
            <div><span>@SortLabel(sortMode)</span><label>Sort</label></div>
        </div>

        @if (!visiblePlayers.Any())
        {
            <p>No players match your search.</p>
        }
        else
        {
        <div class="table-wrap">
            <table class="table table-dark table-striped align-middle">
                <thead>
                    <tr>
                        <th>Player</th>
                        <th>Team</th>
                        <th>Pos</th>
                        <th>Form</th>
                        <th>Points</th>
                        <th>Price</th>
                        <th>Availability</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var player in visiblePlayers)
                    {
                        <tr>
                            <td><a href="@($"players/{player.Id}")">@player.Name</a></td>
                            <td>@player.TeamName</td>
                            <td>@player.Position</td>
                            <td>@player.Form</td>
                            <td>@player.RecentPoints</td>
                            <td>@player.Price</td>
                            <td><span class="badge @BadgeClass(player.AvailabilityStatus)">@player.AvailabilityStatus</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        }
    }
</div>

@code {
    private List<PlayerDto>? players;
    private string search = string.Empty;
    private string positionFilter = string.Empty;
    private string sortMode = "form";

    protected override async Task OnInitializedAsync()
        => players = await Api.GetPlayersAsync() ?? [];

    private IEnumerable<PlayerDto> FilteredPlayers
    {
        get
        {
            IEnumerable<PlayerDto> query = players ?? [];

            if (!string.IsNullOrWhiteSpace(search))
            {
                query = query.Where(player => player.Name.Contains(search, StringComparison.OrdinalIgnoreCase) || player.TeamName.Contains(search, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(positionFilter))
            {
                query = query.Where(player => player.Position.Equals(positionFilter, StringComparison.OrdinalIgnoreCase));
            }

            return sortMode switch
            {
                "price" => query.OrderByDescending(player => player.Price),
                "points" => query.OrderByDescending(player => player.RecentPoints),
                _ => query.OrderByDescending(player => player.Form)
            };
        }
    }

    private static string BadgeClass(AvailabilityStatus status) => status switch
    {
        AvailabilityStatus.Available => "badge-good",
        AvailabilityStatus.Doubtful => "badge-warning",
        AvailabilityStatus.Injured or AvailabilityStatus.RuledOut or AvailabilityStatus.Suspended => "badge-bad",
        _ => "badge-neutral"
    };

    private static string SortLabel(string mode) => mode switch
    {
        "price" => "Price",
        "points" => "Recent points",
        _ => "Recent form"
    };
}
