@page "/models"
@rendermode InteractiveServer
@inject FootballApiClient Api

<PageTitle>Model Status</PageTitle>

<div class="grid-2">
    <article class="panel">
        <div class="hero-copy mb-3">
            Monitor the latest model training runs and the ingestion jobs that feed them.
        </div>
        <div class="button-row mb-3">
            <button class="btn btn-outline-light" disabled="@isBusy" @onclick="Refresh">Refresh</button>
            <button class="btn btn-primary" disabled="@isBusy" @onclick="RetrainAll">Retrain both models</button>
            <button class="btn btn-outline-light" disabled="@isBusy" @onclick="TrainPlayers">Train player model</button>
            <button class="btn btn-outline-light" disabled="@isBusy" @onclick="TrainTeams">Train team model</button>
        </div>

        <div class="hero-stats mb-3">
            <div><span>@(latestModelRun?.Status ?? "None")</span><label>Latest model</label></div>
            <div><span>@(latestIngestionRun?.Status ?? "None")</span><label>Latest sync</label></div>
        </div>

        <h3>Training runs</h3>
        @if (modelRuns is null)
        {
            <p>Loading...</p>
        }
        else
        {
            <div class="hero-stats mb-3">
                <div><span>@modelRuns.Count</span><label>Loaded</label></div>
                <div><span>@modelRuns.Count(run => run.CompletedUtc is null)</span><label>Open</label></div>
            </div>

            @if (modelRuns.Count == 0)
            {
                <p>No training runs are available yet.</p>
            }
            else
            {
                @foreach (var run in modelRuns)
                {
                    <div class="list-row">
                        <span>@run.ModelName</span>
                        <strong>@run.Status - @run.EvaluationMetricName @run.EvaluationMetricValue</strong>
                    </div>
                }
            }
        }
    </article>
    <article class="panel">
        <h3>Data ingestion runs</h3>
        @if (ingestionRuns is null)
        {
            <p>Loading...</p>
        }
        else
        {
            <div class="hero-stats mb-3">
                <div><span>@ingestionRuns.Count</span><label>Loaded</label></div>
                <div><span>@ingestionRuns.Count(run => run.CompletedUtc is null)</span><label>Open</label></div>
            </div>

            @if (ingestionRuns.Count == 0)
            {
                <p>No ingestion runs are available yet.</p>
            }
            else
            {
                @foreach (var run in ingestionRuns)
                {
                    <div class="list-row">
                        <span>@run.SourceName</span>
                        <strong>@run.Status - @run.ItemsProcessed processed</strong>
                    </div>
                }
            }
        }
    </article>
</div>

@code {
    private List<ModelTrainingRunDto>? modelRuns;
    private List<DataIngestionRunDto>? ingestionRuns;
    private ModelTrainingRunDto? latestModelRun;
    private DataIngestionRunDto? latestIngestionRun;
    private bool isBusy;

    protected override async Task OnInitializedAsync()
        => await Refresh();

    private async Task Refresh()
    {
        modelRuns = await Api.GetModelRunsAsync() ?? [];
        ingestionRuns = await Api.GetIngestionRunsAsync() ?? [];
        latestModelRun = modelRuns.FirstOrDefault();
        latestIngestionRun = ingestionRuns.FirstOrDefault();
    }

    private Task RetrainAll() => ExecuteAsync(() => Api.RetrainAsync());

    private Task TrainPlayers() => ExecuteAsync(() => Api.TrainAsync());

    private Task TrainTeams() => ExecuteAsync(() => Api.TrainAsync("team"));

    private async Task ExecuteAsync<T>(Func<Task<T?>> action)
    {
        if (isBusy)
        {
            return;
        }

        isBusy = true;

        try
        {
            await action();
            await Refresh();
        }
        finally
        {
            isBusy = false;
        }
    }
}
