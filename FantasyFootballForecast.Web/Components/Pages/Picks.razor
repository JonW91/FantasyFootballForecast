@page "/picks"
@rendermode InteractiveServer
@inject FootballApiClient Api

<PageTitle>Top Picks</PageTitle>

<div class="grid-2">
    <article class="panel">
        <div class="hero-copy mb-3">
            Review the highest-value fantasy options and the best-XI prototype from the current model output.
        </div>
        <h3>Best picks</h3>
        @if (picks is null)
        {
            <p>Loading...</p>
        }
        else
        {
            <div class="hero-stats mb-3">
                <div><span>@picks.Count</span><label>Loaded</label></div>
                <div><span>@picks.Count(pick => pick.IsSuspended || pick.IsInjuryConcern)</span><label>Flagged</label></div>
            </div>

            @if (picks.Count == 0)
            {
                <p>No pick suggestions are available yet.</p>
            }
            else
            {
                @foreach (var pick in picks)
                {
                    <div class="pick-card">
                        <div>
                            <strong>@pick.PlayerName</strong>
                            <p>@pick.TeamName - @pick.Position</p>
                        </div>
                        <div>
                            <span>@pick.PredictedPoints.ToString("F1") pts</span>
                            <span class="badge @(pick.IsSuspended || pick.IsInjuryConcern ? "badge-warning" : "badge-good")">@pick.RecommendationReason</span>
                        </div>
                    </div>
                }
            }
        }
    </article>

    <article class="panel">
        <h3>Best XI prototype</h3>
        @if (bestXi is null)
        {
            <p>Loading...</p>
        }
        else
        {
            <div class="hero-stats mb-3">
                <div><span>@bestXi.Count</span><label>Loaded</label></div>
                <div><span>@bestXi.Take(11).Count()</span><label>Shown</label></div>
            </div>

            @if (bestXi.Count == 0)
            {
                <p>No best-XI results are available yet.</p>
            }
            else
            {
                @foreach (var pick in bestXi.Take(11))
                {
                    <div class="list-row">
                        <span>@pick.PlayerName</span>
                        <strong>@pick.PredictedPoints.ToString("F1")</strong>
                    </div>
                }
            }
        }
    </article>
</div>

@code {
    private List<FantasyPickDto>? picks;
    private List<FantasyPickDto>? bestXi;

    protected override async Task OnInitializedAsync()
    {
        picks = await Api.GetTopPicksAsync(10) ?? [];
        bestXi = await Api.GetBestXiAsync() ?? [];
    }
}
