@page "/picks"
@rendermode InteractiveServer
@inject FootballApiClient Api
@using System.Globalization

<PageTitle>Top Picks</PageTitle>

<div class="grid-2">
    <article class="panel">
        <div class="hero-copy mb-3">
            Review the highest-value fantasy options and the best-XI prototype from the current model output.
        </div>
        <h3>Best picks</h3>
        @if (picks is null)
        {
            <p>Loading...</p>
        }
        else
        {
            <div class="hero-stats mb-3">
                <div><span>@picks.Count</span><label>Loaded</label></div>
                <div><span>@picks.Count(pick => pick.IsSuspended || pick.IsInjuryConcern)</span><label>Flagged</label></div>
            </div>

            @if (picks.Count == 0)
            {
                <p>No pick suggestions are available yet.</p>
            }
            else
            {
                @foreach (var pick in picks)
                {
                    <div class="pick-card">
                        <div>
                            <strong>@pick.PlayerName</strong>
                            <p>@pick.TeamName - @pick.Position</p>
                        </div>
                        <div>
                            <span>@pick.PredictedPoints.ToString("F1") pts</span>
                            <span class="badge @(pick.IsSuspended || pick.IsInjuryConcern ? "badge-warning" : "badge-good")">@pick.RecommendationReason</span>
                        </div>
                    </div>
                }
            }
        }
    </article>

    <article class="panel">
        <h3>Best XI prototype</h3>
        @if (bestXi is null)
        {
            <p>Loading...</p>
        }
        else
        {
            <div class="hero-stats mb-3">
                <div><span>@bestXi.Count</span><label>Loaded</label></div>
                <div><span>@bestXi.Take(11).Count()</span><label>Shown</label></div>
            </div>

            @if (bestXi.Count == 0)
            {
                <p>No best-XI results are available yet.</p>
            }
            else
            {
                @foreach (var pick in bestXi.Take(11))
                {
                    <div class="list-row">
                        <span>@pick.PlayerName</span>
                        <strong>@pick.PredictedPoints.ToString("F1")</strong>
                    </div>
                }
            }
        }
    </article>
</div>

<article class="panel mt-4">
    <h3>Upcoming fixture difficulty</h3>
    <div class="hero-copy mb-3">
        Difficulty rating for each team's next fixture on a 1 (easiest) to 5 (hardest) scale. Home advantage is factored in.
    </div>
    @if (fixtureDifficulty is null)
    {
        <p>Loading...</p>
    }
    else if (fixtureDifficulty.Count == 0)
    {
        <p>No upcoming fixtures are available yet.</p>
    }
    else
    {
        <div class="table-wrap">
            <table class="table table-dark table-striped align-middle">
                <thead>
                    <tr>
                        <th>Team</th>
                        <th>Opponent</th>
                        <th>H/A</th>
                        <th>Kickoff</th>
                        <th>FDR</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in fixtureDifficulty)
                    {
                        <tr>
                            <td>@row.TeamName</td>
                            <td>@row.OpponentTeamName</td>
                            <td>@(row.IsHome ? "H" : "A")</td>
                            <td>@row.KickoffUtc.ToString("dd MMM HH:mm", CultureInfo.InvariantCulture)</td>
                            <td><span class="badge @FdrBadgeClass(row.Difficulty)">@row.Difficulty</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</article>

@code {
    private List<FantasyPickDto>? picks;
    private List<FantasyPickDto>? bestXi;
    private List<FixtureDifficultyDto>? fixtureDifficulty;

    protected override async Task OnInitializedAsync()
    {
        picks = await Api.GetTopPicksAsync(10) ?? [];
        bestXi = await Api.GetBestXiAsync() ?? [];
        fixtureDifficulty = await Api.GetFixtureDifficultyAsync() ?? [];
    }

    private static string FdrBadgeClass(int difficulty) => difficulty switch
    {
        1 or 2 => "badge-good",
        3 => "badge-neutral",
        _ => "badge-bad"
    };
}
