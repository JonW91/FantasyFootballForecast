@page "/players/{PlayerId:int}"
@rendermode InteractiveServer
@inject FootballApiClient Api
@using System.Globalization

<PageTitle>Player Details</PageTitle>

@if (detail is null)
{
    <p>Loading...</p>
}
else
{
    <section class="hero">
        <div>
            <p class="eyebrow">Player detail</p>
            <h2>@detail.Player.Name</h2>
            <p class="hero-copy">@detail.Team.Name, @detail.Player.Position, squad number @detail.Player.ShirtNumber.</p>
            <a class="btn btn-outline-light btn-sm" href="/players">Back to players</a>
        </div>
        <div class="hero-stats">
            <div><span>@detail.Player.Price</span><label>Price</label></div>
            <div><span>@detail.Player.RecentPoints</span><label>Recent points</label></div>
            <div><span>@detail.Player.Form</span><label>Form</label></div>
        </div>
    </section>

    <div class="grid-3">
        <article class="panel">
            <strong>Availability</strong>
            <p><span class="badge @BadgeClass(detail.CurrentAvailability.AvailabilityStatus)">@detail.CurrentAvailability.AvailabilityStatus</span></p>
            <p>Chance: @detail.CurrentAvailability.ChanceOfPlayingNextRound.ToString("P0", CultureInfo.InvariantCulture)</p>
        </article>
        <article class="panel">
            <strong>Expected return</strong>
            <p>@detail.CurrentAvailability.ExpectedReturnText</p>
        </article>
        <article class="panel">
            <strong>Ownership</strong>
            <p>@detail.Player.OwnershipPercent.ToString("F1", CultureInfo.InvariantCulture)%</p>
        </article>
    </div>

    <div class="grid-2 mt-3">
        <article class="panel">
            <h3>Recent match log</h3>
            @if (detail.RecentMatchStats.Count == 0)
            {
                <p>No match stats available yet.</p>
            }
            else
            {
                <div class="table-wrap">
                    <table class="table table-dark table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Fixture</th>
                                <th>Pts</th>
                                <th>Min</th>
                                <th>G/A</th>
                                <th>Form</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var stat in detail.RecentMatchStats)
                            {
                                <tr>
                                    <td>@(stat.IsHome ? "Home" : "Away") vs @stat.OpponentTeamName</td>
                                    <td>@stat.FantasyPoints</td>
                                    <td>@stat.MinutesPlayed</td>
                                    <td>@stat.Goals-@stat.Assists</td>
                                    <td>@stat.RollingForm</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <article class="panel">
            <h3>News and predictions</h3>
            @if (detail.RecentNews.Count == 0)
            {
                <p>No recent news for this player.</p>
            }
            else
            {
                @foreach (var item in detail.RecentNews)
                {
                    <div class="list-row">
                        <span>@item.Title</span>
                        <strong>@item.Confidence.ToString("P0", CultureInfo.InvariantCulture)</strong>
                    </div>
                }
            }

            <h4 class="mt-3">Latest model signals</h4>
            @if (detail.RecentPredictions.Count == 0)
            {
                <p>No player predictions have been generated yet.</p>
            }
            else
            {
                @foreach (var prediction in detail.RecentPredictions)
                {
                    <div class="list-row">
                        <span>@prediction.PredictionKind</span>
                        <strong>@prediction.PredictedValue.ToString("F2", CultureInfo.InvariantCulture)</strong>
                    </div>
                }
            }
        </article>
    </div>

    <article class="panel mt-3">
        <h3>Availability summary</h3>
        <div class="hero-stats">
            <div><span>@detail.CurrentAvailability.AvailabilityStatus</span><label>Status</label></div>
            <div><span>@detail.CurrentAvailability.AvailabilityConfidence.ToString("P0", CultureInfo.InvariantCulture)</span><label>Confidence</label></div>
            <div><span>@detail.CurrentAvailability.LastVerifiedUtc.ToString("dd MMM HH:mm", CultureInfo.InvariantCulture)</span><label>Updated</label></div>
        </div>
    </article>
}

@code {
    [Parameter] public int PlayerId { get; set; }

    private PlayerDetailDto? detail;

    protected override async Task OnParametersSetAsync()
        => detail = await Api.GetPlayerAsync(PlayerId);

    private static string BadgeClass(AvailabilityStatus status) => status switch
    {
        AvailabilityStatus.Available => "badge-good",
        AvailabilityStatus.Doubtful => "badge-warning",
        AvailabilityStatus.Injured or AvailabilityStatus.RuledOut or AvailabilityStatus.Suspended => "badge-bad",
        _ => "badge-neutral"
    };
}
